{
  "info": {
    "name": "Ludu Game Backend Socket.IO API",
    "description": "Postman Collection containing all documented Socket.IO events for the Ludu game backend.\n\n**Note**: These requests are represented as HTTP POST requests to easily store the JSON payloads. To test them in Postman:\n1. Open a new **Socket.IO Request** in Postman.\n2. Connect to your server URL (e.g. `ws://localhost:16000`).\n3. Set the 'Event Name' to the endpoint path (e.g. `REQ_LOGIN`).\n4. Copy the JSON body from these saved requests and paste them into the Socket.IO message tab.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:16000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 REQ_LOGIN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"logintype\": \"Phone\",\n  \"userphone\": \"string_if_phone\",\n  \"google_id\": \"string_if_google\"\n}"
            },
            "url": { "raw": "{{base_url}}/REQ_LOGIN", "host": ["{{base_url}}"], "path": ["REQ_LOGIN"] },
            "description": "Authenticate a user using phone number or Google ID.\nResponse: GET_LOGIN_RESULT"
          }
        },
        {
          "name": "1.2 REQ_LOGOUT",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userid\": \"string\"\n}"
            },
            "url": { "raw": "{{base_url}}/REQ_LOGOUT", "host": ["{{base_url}}"], "path": ["REQ_LOGOUT"] },
            "description": "Logout the user.\nResponse: None"
          }
        },
        {
          "name": "1.3 REQ_REGISTER",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginMode\": \"phone\",\n  \"username\": \"string\",\n  \"userphone\": \"string\",\n  \"useremail\": \"string\",\n  \"userphoto\": \"string\",\n  \"google_id\": \"string\",\n  \"referral\": \"string\"\n}"
            },
            "url": { "raw": "{{base_url}}/REQ_REGISTER", "host": ["{{base_url}}"], "path": ["REQ_REGISTER"] },
            "description": "Register a new user.\nResponse: GET_REGISTER_RESULT"
          }
        },
        {
          "name": "1.4 REQ_VALID_PHONE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"string\"\n}"
            },
            "url": { "raw": "{{base_url}}/REQ_VALID_PHONE", "host": ["{{base_url}}"], "path": ["REQ_VALID_PHONE"] },
            "description": "Check if a phone number is already registered.\nResponse: REQ_VALID_PHONE_RESULT"
          }
        }
      ]
    },
